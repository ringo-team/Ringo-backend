{
  "analysis": {
    "char_filter": {
      "whitespace_remover": {
        "type": "pattern_replace",
        "pattern": "\\s+",
        "replacement": ""
      }
    },
    "tokenizer": {
      "korean_tokenizer": {
        "type": "nori_tokenizer"
      }
    },
    "filter": {
      "autocomplete_filter": {
        "type": "edge_ngram",
        "min_gram": 1,
        "max_gram": 20
      }
    },
    "analyzer": {
      "index_analyzer": {
        "type": "custom",
        "tokenizer": "whitespace",
        "filter": ["lowercase", "autocomplete_filter"]
      },
      "search_analyzer": {
        "type": "custom",
        "char_filter": ["whitespace_remover"],
        "tokenizer": "korean_tokenizer",
        "filter": ["lowercase"]
      }
    }
  }
}